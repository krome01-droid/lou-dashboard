# LOU Cron jobs — heures locales Paris (Europe/Paris)
# Format : minute hour day-of-month month day-of-week command

# Brief quotidien — tous les jours à 7h
0 7 * * * /usr/local/bin/call-cron.sh daily-brief

# Veille (actualités sécurité routière) — Lun-Ven à 7h
0 7 * * 1-5 /usr/local/bin/call-cron.sh veille

# Posts sociaux — Lun/Mer/Ven à 9h
0 9 * * 1,3,5 /usr/local/bin/call-cron.sh social-auto

# Newsletter — Lundi à 8h
0 8 * * 1 /usr/local/bin/call-cron.sh newsletter

# Rapport SEO — Dimanche à 6h
0 6 * * 0 /usr/local/bin/call-cron.sh seo-report
